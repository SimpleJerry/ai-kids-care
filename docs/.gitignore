######################################################################
# Docs (design documents) - keep sources, ignore outputs/caches
######################################################################

# Keep docs sources (default behavior). Do NOT ignore docs/ entirely.

# Static site generators / build outputs
docs/site/
docs/_site/
docs/.docusaurus/
docs/build/
docs/dist/
docs/public/build/
docs/.vuepress/dist/
docs/.vitepress/cache/
docs/.vitepress/dist/
docs/.mkdocs_cache/

# Sphinx (if used)
docs/_build/

# Node-based docs tooling (if docs has its own package.json)
docs/node_modules/

# Editors / OS junk inside docs
docs/.DS_Store
docs/**/.DS_Store
docs/**/Thumbs.db

# Temporary / backup files
docs/**/.~*
docs/**/*~
docs/**/*.tmp
docs/**/*.bak